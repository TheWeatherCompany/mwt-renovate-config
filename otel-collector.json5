{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  description: "Keeps OpenTelemetry Collector version pins in sync across TheWeatherCompany repos. A repo opts in by adding to its renovate.json: \"extends\": [\"github>TheWeatherCompany/mwt-renovate-config:otel-collector\"]. See README.md for which repos/files this is meant to cover and why.",

  customManagers: [
    {
      // mwt-ee-deploy: Helm chart version for the EKS otel-collector deployment
      // (terraform/compute/services/otel-collector/environments/{dev,stg,prod}.tfvars).
      // Public upstream (open-telemetry Helm repo) - no gating needed.
      customType: "regex",
      managerFilePatterns: [
        "/^terraform/compute/services/otel-collector/environments/.*\\.tfvars$/",
      ],
      matchStrings: [
        "helm_chart_version\\s*=\\s*\"(?<currentValue>[^\"]+)\"",
      ],
      depNameTemplate: "otel-collector-helm-chart",
      packageNameTemplate: "opentelemetry-collector",
      registryUrlTemplate: "https://open-telemetry.github.io/opentelemetry-helm-charts",
      datasourceTemplate: "helm",
    },
    {
      // mwt-ee-deploy: otelcol-contrib image tag baked into the Helm values
      // (same tfvars files as above, separate knob).
      // Public upstream (Docker Hub) - no gating needed.
      customType: "regex",
      managerFilePatterns: [
        "/^terraform/compute/services/otel-collector/environments/.*\\.tfvars$/",
      ],
      matchStrings: [
        "collector_image_tag\\s*=\\s*\"(?<currentValue>[^\"]+)\"",
      ],
      depNameTemplate: "otel-collector-image",
      packageNameTemplate: "otel/opentelemetry-collector-contrib",
      datasourceTemplate: "docker",
    },
    {
      // EC2-classic per-app agent config consumed by mwt-deploy's
      // installOpenTelemetry.sh, e.g. mwt-config-api/scripts/otel-api.json,
      // mwt-forecasteditor-api/otel-*.json, mwt-widgets/otel-web.json, etc.
      //
      // Gated: this datasource is TheWeatherCompany/mwt-observability's own
      // GitHub releases, and mwt-observability's update-observability.yml only
      // tags an otel-collector-vX release *after* sync-binaries has mirrored
      // that version's RPM to S3. This prevents proposing a version that
      // installOpenTelemetry.sh would 404 on at deploy time.
      customType: "regex",
      managerFilePatterns: [
        "/(^|/)otel-[a-zA-Z0-9_-]*\\.json$/",
      ],
      matchStrings: [
        "\"collector_version\"\\s*:\\s*\"(?<currentValue>[^\"]+)\"",
      ],
      depNameTemplate: "otel-collector-rpm",
      datasourceTemplate: "github-releases",
      packageNameTemplate: "TheWeatherCompany/mwt-observability",
      extractVersionTemplate: "^otel-collector-v(?<version>.*)$",
    },
    {
      // mwt-perforce-deploy: same RPM as above, pinned as a Terraform variable
      // default instead of a JSON config (modules/perforce-server/variables.tf).
      // Same gated datasource as the JSON manager above.
      customType: "regex",
      managerFilePatterns: [
        "/^modules/perforce-server/variables\\.tf$/",
      ],
      matchStrings: [
        "variable\\s+\"otel_collector_version\"\\s*\\{[\\s\\S]*?default\\s*=\\s*\"(?<currentValue>[^\"]+)\"",
      ],
      depNameTemplate: "otel-collector-rpm",
      datasourceTemplate: "github-releases",
      packageNameTemplate: "TheWeatherCompany/mwt-observability",
      extractVersionTemplate: "^otel-collector-v(?<version>.*)$",
    },
  ],

  packageRules: [
    // Ordered broadest-first: Renovate merges packageRules in order, later
    // rules override earlier ones on conflicting keys, so the most specific
    // (dev) tier must be listed last to win over the general default.
    {
      description: "Default: treat any file not matched below as prod-tier. Longer soak, and never automerge an OTel Collector bump anywhere - a human always reviews the PR before it ships.",
      matchDepNames: ["otel-collector-helm-chart", "otel-collector-image", "otel-collector-rpm"],
      minimumReleaseAge: "14 days",
      automerge: false,
      groupName: "otel-collector (prod)",
    },
    {
      description: "Staging-tier files: let dev soak for about a week first.",
      matchDepNames: ["otel-collector-helm-chart", "otel-collector-image", "otel-collector-rpm"],
      matchFileNames: ["**/stg.tfvars", "**/*-stg-*", "**/*stg*.json", "**/*staging*"],
      minimumReleaseAge: "7 days",
      groupName: "otel-collector (staging)",
    },
    {
      description: "Dev-tier files: propose immediately, no soak required.",
      matchDepNames: ["otel-collector-helm-chart", "otel-collector-image", "otel-collector-rpm"],
      matchFileNames: ["**/dev.tfvars", "**/*-dev-*", "**/*dev*.json"],
      minimumReleaseAge: "0 days",
      groupName: "otel-collector (dev)",
    },
  ],
}
